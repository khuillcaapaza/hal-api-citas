# ── Entorno ──────────────────────────────────────────────
# true en local (muestra errores), false en producción
APP_DEBUG=false
# '/api' en producción (HestiaCP); vacío en local
APP_BASE_PATH=/api
# true = JWT solo por HTTPS (producción). false en local (HTTP)
APP_SECURE=true

# ── Autenticación JWT ────────────────────────────────────
AUTH_ENABLED=true
# Secreto para firmar tokens (mínimo 32 caracteres aleatorios)
JWT_SECRET=
# Duración del token en segundos (28800 = 8 horas)
JWT_TTL=28800

# ── CORS (orígenes del frontend, separados por coma) ─
CORS_ORIGINS=https://hospitalantoniolorena.gob.pe,https://citas.hospitalantoniolorena.gob.pe

# ── Base de datos MySQL ──────────────────────────────────
DB_HOST=localhost
DB_NAME=haladminweb_bdtest
DB_USER=haladminweb_bdtest
DB_PASS=
